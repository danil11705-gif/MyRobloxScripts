local function sendLog(status, detail)

    local color = 0x2ecc71

    local title = "üöÄ **New Execution**"

    if status == "Banned" then

        color = 0xff0000

        title = "üö´ **Access Denied: Banned User**"

    elseif status == "WrongKey" then

        color = 0xf1c40f

        title = "üîë **Access Denied: Invalid Key Attempt**"

    end

    local data = {

        ["embeds"] = {{

            ["title"] = title,

            ["description"] = "**Status:** " .. detail,

            ["color"] = color,

            ["fields"] = {

                {["name"] = "üë§ User", ["value"] = "`" .. Player.Name .. " (" .. Player.DisplayName .. ")`", ["inline"] = true},

                {["name"] = "üÜî ID", ["value"] = "[" .. Player.UserId .. "](https://www.roblox.com/users/" .. Player.UserId .. "/profile)", ["inline"] = true},

                {["name"] = "üïí Time", ["value"] = os.date("%m.%d.%Y | %X"), ["inline"] = false}

            },

            ["footer"] = {["text"] = "Moglimus Security System"}

        }}

    }

    local request = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request

    if request then

        request({

            Url = WEBHOOK_URL,

            Method = "POST",

            Headers = {["Content-Type"] = "application/json"},

            Body = HttpService:JSONEncode(data)

        })

    end

end



