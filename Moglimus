-- Quick Target with Q
UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.Q then
        local camera = Workspace.CurrentCamera
        local raycastParams = RaycastParams.new()
        raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
        raycastParams.FilterType = Enum.RaycastFilterType.Exclude
        local unitRay = camera:ViewportPointToRay(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
        local raycastResult = Workspace:Raycast(unitRay.Origin, unitRay.Direction * 500, raycastParams)
        if raycastResult and raycastResult.Instance then
            local model = raycastResult.Instance:FindFirstAncestorOfClass("Model")
            if model then
                local target = Players:GetPlayerFromCharacter(model)
                if target and target ~= LocalPlayer then
                    GrabDropdown:SetValue(target.DisplayName)
                    Library:Notify({Title = "Quick Target", Description = "Target: " .. target.DisplayName, Time = 3})
                end
            end
        end
    end
end)

