    if not blob or not targetPlayer.Character then return end
    local Root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not Root or not myRoot then return end
    
    for i = 1, 18 do
        task.wait(0.01)
        blob:PivotTo(Root.CFrame * CFrame.new(0, 25, 0))
    end
    
    blob:PivotTo(Root.CFrame * CFrame.new(0, 20, 0)) 
    task.wait(0.05) 
    
    blob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(blob.RightDetector, Root, blob.RightDetector.RightWeld)
    ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(Root, Root.CFrame)
    task.wait(0.01)
    Root.CFrame = myRoot.CFrame * CFrame.new(0, 20, 0) 
    blob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(blob.RightDetector, Root, blob.RightDetector.RightWeld)
    ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(Root, Root.CFrame)
    task.wait(0.01)
    Root.CFrame = myRoot.CFrame * CFrame.new(0, 20, 0)
    task.wait(0.05)
    blob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(blob.RightDetector, Root, blob.RightDetector.RightWeld)
    task.wait(0.01)
    blob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(blob.RightDetector, myRoot, blob.RightDetector.RightWeld)
    task.wait(0.01)
    blob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(blob.RightDetector, Root, blob.RightDetector.RightWeld)
    task.wait(0.01)
    blob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(blob.RightDetector, myRoot, blob.RightDetector.RightWeld)
    blob.BlobmanSeatAndOwnerScript.CreatureGrab:FireServer(blob.RightDetector, myRoot, blob.RightDetector.RightWeld)
end

