-- ==================== UTILITY FUNCTIONS ====================
local function Notify(title, content, duration)
    Library:Notify({
        Title = title or "Notification",
        Description = content or "",
        Time = duration or 5,
    })
end

local function GetCharacter(player)
    if typeof(player) == "Instance" and player:IsA("Player") then
        return player.Character
    end
    return nil
end

local function GetHumanoidRootPart(player)
    local char = GetCharacter(player)
    if char then
        return char:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

local function GetHead(player)
    local char = GetCharacter(player)
    if char then
        return char:FindFirstChild("Head")
    end
    return nil
end

local function GetHumanoid(player)
    local char = GetCharacter(player)
    if char then
        return char:FindFirstChildOfClass("Humanoid")
    end
    return nil
end

local function IsPlayerValid(player)
    if not player or not player.Parent then return false end
    local char = GetCharacter(player)
    if not char then return false end
    local hum = GetHumanoid(player)
    if not hum or hum.Health <= 0 then return false end
    return true
end

local function GetAllPlayers()
    local list = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            table.insert(list, plr.Name .. " (" .. plr.DisplayName .. ")")
        end
    end
    return list
end

local function GetPlayerFromSelection(selection)
    if not selection then return nil end
    local username = selection:match("%((.-)%)")
    if not username then
        username = selection:match("%((.-)%)")
    end
    if username then
        return Players:FindFirstChild(username)
    end
    return nil
end

local function InvisTouch(part)
    if part and part:IsA("BasePart") then
        SetNetworkOwner:FireServer(part, part.CFrame)
    end
end

