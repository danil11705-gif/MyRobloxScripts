-- // --- IGNORE BARRIER LOGIC --- //

MainGroup:AddToggle("NoBarriers", {
    Text = "Ignore Plot Barriers",
    Default = false,
    Tooltip = "Deaktiviert Kollision für Plot-Barrieren",
    Callback = function(Value)
        local plots = workspace:FindFirstChild("Plots")
        if plots then
            for _, plot in ipairs(plots:GetChildren()) do
                local b = plot:FindFirstChild("Barrier")
                if b then
                    for _, part in ipairs(b:GetDescendants()) do
                        if part:IsA("BasePart") then 
                            part.CanCollide = not Value 
                        end
                    end
                end
            end
        end
    end
})

