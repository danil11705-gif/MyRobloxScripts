MiscGroup2:AddToggle("MasslessGrab", {
    Text = "Massless Grab",
    Default = false,
    Callback = function(Value)
        MasslessEnabled = Value
        if Value then
            local DEFAULT_POWER = 320
            local BASE_RESPONSIVENESS = 200
            local POWER_SCALE = BASE_RESPONSIVENESS / DEFAULT_POWER
            
            MasslessConnection = RunService.Heartbeat:Connect(function()
                if not MasslessEnabled then return end
                local GrabParts = Workspace:FindFirstChild("GrabParts")
                if not GrabParts then return end
                
                local responsiveness = math.clamp(MasslessPower * POWER_SCALE, 40, 300)
                
                for _, v in pairs(GrabParts:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.Massless = true
                        v.CanCollide = false
                        v.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
                    end
                    if v:IsA("AlignPosition") then
                        v.MaxForce = math.huge
                        v.MaxVelocity = math.huge
                        v.Responsiveness = responsiveness
                    end
                    if v:IsA("AlignOrientation") then
                        v.MaxTorque = math.huge
                        v.MaxAngularVelocity = math.huge
                        v.Responsiveness = responsiveness
                    end
                end
            end)
        else
            if MasslessConnection then
                MasslessConnection:Disconnect()
                MasslessConnection = nil
            end
